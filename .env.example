# Copy to .env and fill in. Never commit the real token.

# ── Hub (server) — used by `docker compose` / `npm run office` ──
OFFICE_TOKEN=               # REQUIRED on a public host. Use a long random secret.
OFFICE_PORT=3977
OFFICE_HOST=0.0.0.0         # 127.0.0.1 for local-only
# Optional tuning (defaults shown):
# OFFICE_RATE_LIMIT=240
# OFFICE_MAX_BODY=65536
# OFFICE_STATE_PATH=/data/office-state.json
# OFFICE_TRUST_PROXY=0

# ── Client (each Claude session) ──
# OFFICE_URL=http://your-hub-host:3977
# OFFICE_TOKEN=same-token-as-the-hub
